# Copy this file to .env.local before running the app.

# Required: API key for your OpenAI-compatible provider.
OPENAI_API_KEY=your_api_key_here

# Optional: compatible base URL. Keep the /v1 suffix.
OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: chat completions model used by the PVZTI result route.
OPENAI_MODEL=gpt-4.1-mini

# Optional: override the container image used by docker compose.
# Example: ghcr.io/ji233-sun/pvzti:sha-abcdef1
# PVZTI_IMAGE=ghcr.io/ji233-sun/pvzti:latest
